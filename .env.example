# .env.example

# Django secret key
SECRET_KEY=your_secret_key_here

# Debug mode: True or False
DEBUG=True

# PostgreSQL Database
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Frontend API URL (si aplica)
REACT_APP_API_URL=http://localhost:8000/api/
